generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────────────────────

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    password      String?
    role          String    @default("user")
    accounts      Account[]
    sessions      Session[]
    orders        Order[]
    licenses      License[]
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── Contact ───────────────────────────────────────────────────

model ContactMessage {
    id        String   @id @default(cuid())
    name      String
    email     String
    subject   String
    message   String
    createdAt DateTime @default(now())
}

// ─── Products & Plans ──────────────────────────────────────────

model Product {
    id          String    @id @default(cuid())
    slug        String    @unique
    name        String
    type        String    @default("desktop") // "desktop" | "web" | "module"
    description String?
    isActive    Boolean   @default(true)
    createdAt   DateTime  @default(now())
    plans       Plan[]
    orders      Order[]
    licenses    License[]
}

model Plan {
    id             String       @id @default(cuid())
    productId      String
    slug           String
    name           String
    priceVnd       Int
    priceUsd       Int?
    durationDays   Int? // null = lifetime
    maxActivations Int          @default(1)
    usageLimit     Int? // null = unlimited
    features       Json?
    isActive       Boolean      @default(true)
    product        Product      @relation(fields: [productId], references: [id])
    display        PlanDisplay?

    @@unique([productId, slug])
}

model PlanDisplay {
    id          String  @id @default(cuid())
    planId      String  @unique
    plan        Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
    taglineVi   String?
    taglineEn   String?
    highlightVi String?
    highlightEn String?
    ctaVi       String?
    ctaEn       String?
    emoji       String?
    sortOrder   Int     @default(0)
    isFeatured  Boolean @default(false)
}

// ─── Orders ────────────────────────────────────────────────────

model Order {
    id              String    @id @default(cuid())
    productId       String?
    userId          String?
    buyerEmail      String?
    source          String    @default("web") // "web" | "telegram" | "zalo" | "admin"
    plan            String
    amount          Int
    currency        String    @default("vnd")
    status          String    @default("pending")
    paymentMethod   String    @default("stripe")
    stripeSessionId String?   @unique
    paidAt          DateTime?
    createdAt       DateTime  @default(now())
    user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
    product         Product?  @relation(fields: [productId], references: [id])
    license         License?

    @@index([userId])
    @@index([status])
    @@index([createdAt])
    @@index([productId])
}

// ─── Unified License ──────────────────────────────────────────

model License {
    id                 String          @id @default(cuid())
    productId          String?
    userId             String?
    orderId            String?         @unique
    key                String          @unique
    email              String?
    contactInfo        String?
    source             String          @default("web") // "web" | "telegram" | "zalo" | "admin"
    plan               String
    tier               String          @default("basic")
    status             String          @default("active")
    hwidHash           String?
    maxActivations     Int             @default(1)
    currentActivations Int             @default(0)
    usageLimit         Int?
    currentUsage       Int             @default(0)
    lastSeen           DateTime?
    note               String?
    activatedAt        DateTime        @default(now())
    expiresAt          DateTime?
    createdAt          DateTime        @default(now())
    user               User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
    product            Product?        @relation(fields: [productId], references: [id])
    order              Order?          @relation(fields: [orderId], references: [id])
    activationLogs     ActivationLog[]

    @@index([userId])
    @@index([productId])
    @@index([status])
    @@index([email])
    @@index([hwidHash])
    @@index([createdAt])
}

// ─── Desktop Activation ───────────────────────────────────────

model ActivationLog {
    id        Int      @id @default(autoincrement())
    licenseId String   @map("license_id")
    hwidHash  String   @map("hwid_hash")
    ipAddress String?  @map("ip_address")
    timestamp DateTime @default(now())
    license   License  @relation(fields: [licenseId], references: [id])

    @@index([licenseId])
    @@index([hwidHash])
    @@map("activation_logs")
}

model SessionSecret {
    hwidHash      String   @id @map("hwid_hash")
    sessionSecret String   @map("session_secret")
    createdAt     DateTime @default(now()) @map("created_at")
    expiresAt     DateTime @map("expires_at")

    @@map("session_secrets")
}
